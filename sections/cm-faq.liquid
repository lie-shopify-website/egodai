{% schema %}
    {
        "name": "新版FAQ",
        "settings": [
            { "type": "header","content":"定位设置"},
            { "type": "select", "id": "floor_number", "label": "楼层序号", "options": [
                    { "value": "", "label": "不设置" },
                    { "value": "1", "label": "1" },
                    { "value": "2", "label": "2" },
                    { "value": "3", "label": "3" },
                    { "value": "4", "label": "4" },
                    { "value": "5", "label": "5" },
                    { "value": "6", "label": "6" },
                    { "value": "7", "label": "7" },
                    { "value": "8", "label": "8" },
                    { "value": "9", "label": "9" },
                    { "value": "10", "label": "10" },
                    { "value": "11", "label": "11" },
                    { "value": "12", "label": "12" },
                    { "value": "13", "label": "13" },
                    { "value": "14", "label": "14" },
                    { "value": "15", "label": "15" },
                    { "value": "16", "label": "16" },
                    { "value": "17", "label": "17" },
                    { "value": "18", "label": "18" },
                    { "value": "19", "label": "19" },
                    { "value": "20", "label": "20" }
                ],
                "default": ""
            },

            { "type": "header","content":"标题"},
            { "type": "textarea", "id": "section_title", "label": "大标题" },
            { "type": "textarea", "id": "section_info", "label": "内容" },


            { "type": "header","content":"其他"},
            { "type": "color", "id": "background", "label": "背景", "default": "#d8d7d3" },
            { "type": "color", "id": "text_color", "label": "文字颜色", "default": "#000000" },
            { "type": "select", "id": "container_width", "label": "容器宽度", "options": [
                    { "value": "full_width", "label": "全宽" },
                    { "value": "1440", "label": "1440px" }
                ],
                "default": "1440"
            },
            { "type": "checkbox", "id": "remove_top_padding", "label": "移除上边距", "default": false },
            { "type": "checkbox", "id": "remove_bottom_padding", "label": "移除下边距", "default": false },
            { "type": "text", "id": "custom_class", "label": "自定义class" }
        ],
        "blocks": [
            {
                "type": "questions",
                "name": "FAQ",
                "settings": [
                    { "type": "text", "id": "questions_title", "label": "问题" },
                    { "type": "richtext", "id": "questions_richtext", "label": "答案" }
                ]
            }
        ],

        "presets": [
            {
                "name": "新版FAQ",
                "category": "custom"
            }
        ]
    }
{% endschema %}


<div data-section-id="{{ section.id }}" class="cm-faq-layout" {% if section.settings.floor_number != blank %}data-floor-number="{{ section.settings.floor_number }}"{% endif %}>

<div class="cm-faq {{ section.settings.custom_class }} {% if section.settings.remove_top_padding %}remove-top-space{% endif %} {% if section.settings.remove_bottom_padding %}remove-bottom-space{% endif %}">

    {{ 'cm-faq.css' | asset_url | stylesheet_tag }}
    <style>
        [data-section-id="{{ section.id }}"] {
            --background-color: {{ section.settings.background }};
            --text_color: {{ section.settings.text_color }};
        }
        {% if section.settings.container_width == '1440' %}
            [data-section-id="{{ section.id }}"] .layout-container {
              max-width: 1440px;
              margin: 0 auto;
            }
        {% else %}
            [data-section-id="{{ section.id }}"] .layout-container {
              max-width: 100%;
            }
        {% endif %}
    </style>

    <div class="layout-container">
        {% if section.settings.section_title != blank or section.settings.section_info != blank %}
        <div class="heading-box">
            {% if section.settings.section_title != blank %}
                <div class="section-title"><h2 class="slide_title-inner">{{ section.settings.section_title }}</h2></div>
            {% endif %}
            {% if section.settings.section_info != blank %}
                <div class="section-info"><p>{{ section.settings.section_info }}</p></div>
            {% endif %}
        </div>
        {% endif %}

        <div class="content-layout">
            <div class="faq-list">
                <div class="faq-items">
                    {% for block in section.blocks %}
                        {% assign question = block.settings.questions_title %}
                        {% assign answer = block.settings.questions_richtext %}
                        {% if question != blank and answer != blank %}  
                            <div class="faq-item js-faqItem">
                                <div class="faq-question">
                                    <h3>{{ question }}</h3>
                                    <span class="arrow arrow-down accordion-toggle">
                                        <svg class="accordion-icon-svg" viewBox="0 0 24 24" width="24" height="24" fill="none">
                                            <path d="M20 8L12 16L4 8" stroke="white" stroke-width="1.5" stroke-linejoin="round">
                                              <animate class="expandAnim" attributeName="d" 
                                                values="M20 8L12 16L4 8; M21.5 12L12 12L2.5 12; M20 16L12 8L4 16" 
                                                dur="320ms" begin="indefinite" fill="freeze" keyTimes="0;0.5;1" 
                                                calcMode="spline" keySplines="0.12, 0, 0.38, 0; 0.2, 1, 0.68, 1"
                                              ></animate>
                                              <animate class="collapseAnim" attributeName="d" 
                                                values="M20 16L12 8L4 16; M21.5 12L12 12L2.5 12; M20 8L12 16L4 8" 
                                                dur="320ms" begin="indefinite" fill="freeze" keyTimes="0;0.5;1" 
                                                calcMode="spline" keySplines="0.2, 0, 0.68, 0; 0.2, 1, 0.68, 1"
                                              ></animate>
                                            </path>
                                        </svg>
                                    </span>
                                </div>
                                <div class="faq-answer">
                                    <div class="faq-answer-content js-faqAnswerContent">
                                        <div class="faq-answer-inner">
                                            <div class="faq-answer-text">{{ answer }}</div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        {% endif %}
                    {% endfor %}
                </div>
            </div>
        </div>
    </div>

</div>
</div>


<script>
    ;(function() {
        const sectionId = '{{ section.id }}';
        const SECTION_SELECTOR = '[data-section-id="{{ section.id }}"]';
        const DOM_READY_EVENT = 'DOMContentLoaded';
        let sectionEl = null;
        let splideInstance = null;

        function init() {
            sectionEl = document.querySelector(SECTION_SELECTOR);
            if (!sectionEl) return;

            initFaqToggle();
        }
    
        function initFaqToggle() {
            const faqItems = sectionEl.querySelectorAll('.js-faqItem');
            faqItems.forEach(faqItem => {
                faqItem.addEventListener("click", (e) => {
                    if (!e.target.closest('.faq-question')) return;
                    e.preventDefault();
                    e.stopPropagation();
                    
                    faqItems.forEach(item => {
                        if (item !== faqItem) {
                            if (item.classList.contains('open')) {
                                item.classList.remove('open');
                                updateArrowState(item, false);
                            }
                        }
                    });
                    
                    faqItem.classList.toggle('open');
                    updateArrowState(faqItem, faqItem.classList.contains('open'));
                });
            });
        }

        function updateArrowState(element, shouldExpand) {
            const arrowBtn = element.querySelector('.accordion-toggle');
            if (!arrowBtn) return;
            
            const expandAnim = arrowBtn.querySelector('.expandAnim');
            const collapseAnim = arrowBtn.querySelector('.collapseAnim');
            
            if (!expandAnim || !collapseAnim) return;
            
            const currentExpanded = arrowBtn.getAttribute('aria-expanded') === 'true';
            if (currentExpanded === shouldExpand) return;
            
            try {
                expandAnim.endElement();
                collapseAnim.endElement();
                
                if (shouldExpand) {
                    expandAnim.beginElement();
                    arrowBtn.setAttribute('aria-expanded', 'true');
                } else {
                    collapseAnim.beginElement();
                    arrowBtn.setAttribute('aria-expanded', 'false');
                }
            } catch(err) {}
        }

        window.addEventListener(DOM_READY_EVENT, () => {
            init();
        });
    })();
</script>
