
{% schema %}
    {
        "name": "图文混排",
        "settings": [
            { "type": "header","content":"定位设置"},
            { "type": "select", "id": "floor_number", "label": "楼层序号", "options": [
                    { "value": "", "label": "不设置" },
                    { "value": "1", "label": "1" },
                    { "value": "2", "label": "2" },
                    { "value": "3", "label": "3" },
                    { "value": "4", "label": "4" },
                    { "value": "5", "label": "5" },
                    { "value": "6", "label": "6" },
                    { "value": "7", "label": "7" },
                    { "value": "8", "label": "8" },
                    { "value": "9", "label": "9" },
                    { "value": "10", "label": "10" },
                    { "value": "11", "label": "11" },
                    { "value": "12", "label": "12" },
                    { "value": "13", "label": "13" },
                    { "value": "14", "label": "14" },
                    { "value": "15", "label": "15" },
                    { "value": "16", "label": "16" },
                    { "value": "17", "label": "17" },
                    { "value": "18", "label": "18" },
                    { "value": "19", "label": "19" },
                    { "value": "20", "label": "20" }
                ],
                "default": ""
            },
            { "type": "header","content":"标题"},
            { "type": "textarea", "id": "section_title", "label": "大标题" },
            { "type": "textarea", "id": "section_info", "label": "内容" },
            { "type": "checkbox", "id": "remove_top_padding", "label": "移除上边距", "default": false },
            { "type": "checkbox", "id": "remove_bottom_padding", "label": "移除下边距", "default": false },
            { "type": "select", "id": "container_width", "label": "容器宽度", "options": [
                    { "value": "full_width", "label": "全宽" },
                    { "value": "1440", "label": "1440px" }
                ],
                "default": "1440"
            },
            { "type": "color", "id": "background_color", "label": "背景色", "default": "#ffffff" },
            { "type": "text", "id": "custom_class", "label": "自定义class" }
        ],
        "blocks": [
            {
                "type": "media_text",
                "name": "图文",
                "settings": [
                    { "type": "header","content":"媒体"},
                    { "type": "select", "id": "media_type", "label": "媒体类型", "options": [
                            { "value": "image", "label": "图片" },
                            { "value": "video", "label": "视频" }
                        ],
                        "default": "image"
                    },
                    { "type": "image_picker", "id": "image_mobile", "label": "手机端图片" },
                    { "type": "image_picker", "id": "image_desktop", "label": "电脑端图片" },
                    { "type": "image_picker", "id": "image", "label": "通用图片（未单独设置手机/电脑时使用）" },
                    { "type": "video", "id": "video_mobile", "label": "手机端视频" },
                    { "type": "video", "id": "video_desktop", "label": "电脑端视频" },
                    { "type": "video", "id": "video", "label": "通用视频（未单独设置手机/电脑时使用）" },
                    { "type": "image_picker", "id": "poster_image", "label": "视频封面图（可选）" },
                    { "type": "select", "id": "ratio_mobile", "label": "手机端比例", "options": [
                            { "value": "auto", "label": "自动" },
                            { "value": "16/9", "label": "16:9" },
                            { "value": "1/1", "label": "1:1" },
                            { "value": "4/3", "label": "4:3" },
                            { "value": "3/4", "label": "3:4" },
                            { "value": "3/2", "label": "3:2" },
                            { "value": "2/1", "label": "2:1" },
                            { "value": "21/9", "label": "21:9" }
                        ],
                        "default": "16/9"
                    },
                    { "type": "select", "id": "ratio_desktop", "label": "电脑端比例", "options": [
                            { "value": "auto", "label": "自动" },
                            { "value": "16/9", "label": "16:9" },
                            { "value": "1/1", "label": "1:1" },
                            { "value": "4/3", "label": "4:3" },
                            { "value": "3/4", "label": "3:4" },
                            { "value": "3/2", "label": "3:2" },
                            { "value": "2/1", "label": "2:1" },
                            { "value": "21/9", "label": "21:9" }
                        ],
                        "default": "16/9"
                    },
                    { "type": "header","content":"布局"},
                    { "type": "select", "id": "layout_direction", "label": "布局方向（桌面端）", "options": [
                            { "value": "image_left", "label": "左图右文" },
                            { "value": "image_right", "label": "左文右图" }
                        ],
                        "default": "image_left"
                    },
                    { "type": "header","content":"内容"},
                    { "type": "textarea", "id": "subheading", "label": "小标题" },
                    { "type": "textarea", "id": "heading", "label": "大标题" },
                    { "type": "textarea", "id": "content", "label": "内容" },
                    { "type": "header","content":"按钮"},
                    { "type": "textarea", "id": "button_label", "label": "按钮文字" },
                    { "type": "url", "id": "button_link", "label": "按钮链接" },
                    { "type": "color", "id": "button_bg_color", "label": "按钮背景色", "default": "#FED100" },
                    { "type": "color", "id": "button_text_color", "label": "按钮文字色", "default": "#141414" }
                ]
            }
        ],
        "presets": [
            {
                "name": "图文混排",
                "category": "custom"
            }
        ]
    }
{% endschema %}



{{ 'cm-media-with-text.css' | asset_url | stylesheet_tag }}

{% style %}
  [data-section-id="{{ section.id }}"] {
    background-color: {{ section.settings.background_color }};
  }

  {% if section.settings.container_width == '1440' %}
    [data-section-id="{{ section.id }}"] .layout-container {
      max-width: 1440px;
      margin: 0 auto;
    }
  {% else %}
    [data-section-id="{{ section.id }}"] .layout-container {
      max-width: 100%;
    }
  {% endif %}

  {% for block in section.blocks %}
    {%- liquid
      assign mwt_auto_m_ok = false
      assign mwt_auto_d_ok = false
      if block.settings.media_type == 'video'
        assign mwt_video_mobile = block.settings.video_mobile
        assign mwt_video_desktop = block.settings.video_desktop
        if mwt_video_mobile == blank
          assign mwt_video_mobile = block.settings.video
        endif
        if mwt_video_desktop == blank
          assign mwt_video_desktop = block.settings.video
        endif
        if mwt_video_mobile == blank and mwt_video_desktop != blank
          assign mwt_video_mobile = mwt_video_desktop
        endif
        assign mwt_video_for_mobile = mwt_video_mobile
        if mwt_video_desktop != blank
          assign mwt_video_for_desktop = mwt_video_desktop
        else
          assign mwt_video_for_desktop = mwt_video_for_mobile
        endif
        if mwt_video_for_mobile != blank
          assign mwt_auto_m_ok = true
          assign mwt_auto_m_ar = mwt_video_for_mobile.aspect_ratio
        endif
        if mwt_video_for_desktop != blank
          assign mwt_auto_d_ok = true
          assign mwt_auto_d_ar = mwt_video_for_desktop.aspect_ratio
        endif
      else
        assign mwt_image_mobile = block.settings.image_mobile
        assign mwt_image_desktop = block.settings.image_desktop
        if mwt_image_mobile == blank
          assign mwt_image_mobile = block.settings.image
        endif
        if mwt_image_desktop == blank
          assign mwt_image_desktop = block.settings.image
        endif
        if mwt_image_mobile == blank and mwt_image_desktop != blank
          assign mwt_image_mobile = mwt_image_desktop
        endif
        assign mwt_image_for_mobile = mwt_image_mobile
        if mwt_image_desktop != blank
          assign mwt_image_for_desktop = mwt_image_desktop
        else
          assign mwt_image_for_desktop = mwt_image_for_mobile
        endif
        if mwt_image_for_mobile != blank
          assign mwt_auto_m_ok = true
          assign mwt_auto_m_ar = mwt_image_for_mobile.aspect_ratio
        endif
        if mwt_image_for_desktop != blank
          assign mwt_auto_d_ok = true
          assign mwt_auto_d_ar = mwt_image_for_desktop.aspect_ratio
        endif
      endif
    -%}
    [data-section-id="{{ section.id }}"] [data-block-id="{{ block.id }}"] .cm-media-with-text__media--mobile {
      {% if block.settings.ratio_mobile == 'auto' %}
        {% if mwt_auto_m_ok %}
          aspect-ratio: {{ mwt_auto_m_ar }};
        {% else %}
          aspect-ratio: auto;
        {% endif %}
        height: auto;
      {% else %}
        aspect-ratio: {{ block.settings.ratio_mobile }};
      {% endif %}
    }
    @media screen and (min-width: 750px) {
      [data-section-id="{{ section.id }}"] [data-block-id="{{ block.id }}"] .cm-media-with-text__media--desktop {
        {% if block.settings.ratio_desktop == 'auto' %}
          {% if mwt_auto_d_ok %}
            aspect-ratio: {{ mwt_auto_d_ar }};
          {% else %}
            aspect-ratio: auto;
          {% endif %}
          height: auto;
        {% else %}
          aspect-ratio: {{ block.settings.ratio_desktop }};
        {% endif %}
      }
    }
  {% endfor %}
{% endstyle %}

<div class="cm-media-with-text {{ section.settings.custom_class }} {% if section.settings.remove_top_padding %}cm-remove-top-space{% endif %} {% if section.settings.remove_bottom_padding %}cm-remove-bottom-space{% endif %}" data-section-id="{{ section.id }}" {% if section.settings.floor_number != blank %}data-floor-number="{{ section.settings.floor_number }}"{% endif %}>
  <div class="layout-container">
    {% if section.settings.section_title != blank or section.settings.section_info != blank %}
      <div class="heading-box">
          {% if section.settings.section_title != blank %}
              <div class="section-title"><h2 class="slide_title-inner">{{ section.settings.section_title }}</h2></div>
          {% endif %}
          {% if section.settings.section_info != blank %}
              <div class="section-info"><p>{{ section.settings.section_info }}</p></div>
          {% endif %}
      </div>
    {% endif %}

    {% for block in section.blocks %}
      <div class="cm-media-with-text__item {% if block.settings.layout_direction == 'image_right' %}cm-media-with-text__item--reverse{% endif %}" data-block-id="{{ block.id }}">
        <div class="cm-media-with-text__media-wrapper">
          <div class="cm-media-with-text__media cm-media-with-text__media--mobile cm-media-with-text__media--desktop">
            {%- if block.settings.button_link != blank -%}
              <a href="{{ block.settings.button_link }}"></a>
            {%- endif -%}
            
            {%- if block.settings.media_type == 'video' -%}
              {% comment %} 视频 {% endcomment %}
              {%- liquid
                assign video_mobile = block.settings.video_mobile
                assign video_desktop = block.settings.video_desktop
                if video_mobile == blank
                  assign video_mobile = block.settings.video
                endif
                if video_desktop == blank
                  assign video_desktop = block.settings.video
                endif
                if video_mobile == blank and video_desktop != blank
                  assign video_mobile = video_desktop
                endif
              -%}
              
              {%- if video_mobile != blank or video_desktop != blank -%}
                {% liquid
                  if video_desktop != blank
                    assign video_url = video_desktop.sources[0].url
                    assign video_poster = video_desktop.previewImage.url
                    if video_desktop.sources[1].url != blank
                      assign video_url = video_desktop.sources[1].url
                    endif
                  else
                    assign video_url = video_mobile.sources[0].url
                    assign video_poster = video_mobile.previewImage.url
                    if video_mobile.sources[1].url != blank
                      assign video_url = video_mobile.sources[1].url
                    endif
                  endif
                  
                  if video_mobile != blank
                    assign video_mb_url = video_mobile.sources[0].url
                    assign video_mb_poster = video_mobile.previewImage.url
                    if video_mobile.sources[1].url != blank
                      assign video_mb_url = video_mobile.sources[1].url
                    endif
                  else
                    assign video_mb_url = video_url
                    assign video_mb_poster = video_poster
                  endif
                  
                  if block.settings.poster_image != blank
                    assign poster_url = block.settings.poster_image | image_url: width: 1920
                  else
                    assign poster_url = video_poster
                  endif
                %}
                <mf-video 
                  class="cm-media-with-text__video"
                  autoplay 
                  muted 
                  playsinline
                  webkit-playsinline
                  loop
                  preload="metadata"
                >
                  <source src="{{ video_url }}" type="video/mp4" media="(min-width: 1280px)" poster="{{ poster_url }}">
                  <source src="{{ video_url }}" type="video/mp4" media="(min-width: 768px)" poster="{{ poster_url }}">
                  <source src="{{ video_mb_url }}" type="video/mp4" poster="{{ poster_url }}">
                </mf-video>
              {%- else -%}
                <div class="cm-media-with-text__placeholder">
                  {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
                </div>
              {%- endif -%}
            {%- else -%}
              {% comment %} 图片 {% endcomment %}
              {%- liquid
                assign img_mobile = block.settings.image_mobile
                assign img_desktop = block.settings.image_desktop
                if img_mobile == blank
                  assign img_mobile = block.settings.image
                endif
                if img_desktop == blank
                  assign img_desktop = block.settings.image
                endif
                if img_mobile == blank and img_desktop != blank
                  assign img_mobile = img_desktop
                endif
                assign img_for_mobile = img_mobile
                if img_desktop != blank
                  assign img_for_desktop = img_desktop
                else
                  assign img_for_desktop = img_for_mobile
                endif
              -%}
              {%- if img_for_mobile != blank or img_for_desktop != blank -%}
                {% liquid
                  if img_for_desktop != blank
                    assign pc_src = img_for_desktop | image_url: width: 1980
                    assign pad_src = img_for_desktop | image_url: width: 1536
                  else
                    assign pc_src = img_for_mobile | image_url: width: 1980
                    assign pad_src = img_for_mobile | image_url: width: 1536
                  endif
                  assign m_src = img_for_mobile | image_url: width: 767
                %}
                {% render 'resp-img'
                  pc_src: pc_src,
                  pad_src: pad_src,
                  m_src: m_src,
                  lazy: true, 
                  class_name: 'cm-media-with-text__picture'
                %}
              {%- else -%}
                <div class="cm-media-with-text__placeholder">
                  {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
                </div>
              {%- endif -%}
            {%- endif -%}
          </div>
        </div>

        <div class="cm-media-with-text__content">
          <div class="cm-media-with-text__content-inner">
            {%- if block.settings.subheading != blank -%}
              <div class="cm-slide-sub-title">{{ block.settings.subheading }}</div>
            {%- endif -%}
            {%- if block.settings.heading != blank -%}
              <div class="cm-slide-title"><p class="cm-slide-title-inner">{{ block.settings.heading }}</p></div>
            {%- endif -%}
            {%- if block.settings.content != blank -%}
              <div class="cm-slide-info">{{ block.settings.content }}</div>
            {%- endif -%}
            
            {%- if block.settings.button_label != blank and block.settings.button_link != blank -%}
              <div class="cm-slide-button" style="--cm-slide-button-color:{{ block.settings.button_text_color }};--cm-slide-button-bg:{{ block.settings.button_bg_color }};">
                <a href="{{ block.settings.button_link }}" class="mf-btn"><span>{{ block.settings.button_label }}</span></a>
              </div>
            {%- endif -%}
          </div>
        </div>
      </div>
    {% endfor %}
  </div>
</div>
